OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/
OAUTH_FAILURE_REDIRECT_URL=http://localhost:3000/auth/login?oauth=failed

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
