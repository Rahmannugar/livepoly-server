NODE_ENV=production
PORT=3002
API_PUBLIC_URL=https://api.livepoly.site
API_DOMAIN=api.livepoly.site
NGINX_TEMPLATE=http.conf.template

POSTGRES_DB=livepoly
POSTGRES_USER=livepoly
POSTGRES_PASSWORD=CHANGE_TO_A_LONG_ALPHANUMERIC_PASSWORD
DATABASE_URL=postgresql://livepoly:CHANGE_ME@pgbouncer:6432/livepoly
MIGRATION_DATABASE_URL=postgresql://livepoly:CHANGE_ME@postgres:5432/livepoly

REDIS_PASSWORD=CHANGE_TO_A_LONG_ALPHANUMERIC_PASSWORD
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

JWT_ACCESS_SECRET=CHANGE_TO_AT_LEAST_32_RANDOM_CHARACTERS

NEW_RELIC_ENABLED=true
NEW_RELIC_APP_NAME=LivePoly Server
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_LOG_LEVEL=info

MAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.livepoly.site/api/auth/oauth/google/callback
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=https://api.livepoly.site/api/auth/oauth/discord/callback
OAUTH_SUCCESS_REDIRECT_URL=https://livepoly.site/
OAUTH_FAILURE_REDIRECT_URL=https://livepoly.site/auth/login?oauth=failed

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=livepoly-user-image
R2_PUBLIC_BASE_URL=
R2_AVATAR_MAX_BYTES=10485760

BACKUP_S3_URI=s3://CHANGE_ME/livepoly/postgres
