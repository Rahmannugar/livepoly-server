NODE_ENV=production
PORT=3002
API_PUBLIC_URL=https://api.livepoly.site
API_DOMAIN=api.livepoly.site
NGINX_TEMPLATE=http.conf.template

POSTGRES_DB=livepoly
POSTGRES_USER=livepoly
POSTGRES_PASSWORD=CHANGE_TO_A_LONG_ALPHANUMERIC_PASSWORD

REDIS_PASSWORD=CHANGE_TO_A_LONG_ALPHANUMERIC_PASSWORD

JWT_ACCESS_SECRET=CHANGE_TO_AT_LEAST_32_RANDOM_CHARACTERS

NEW_RELIC_ENABLED=true
NEW_RELIC_APP_NAME=LivePoly Server
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_LOG_LEVEL=info
NEW_RELIC_INFRA_ENABLED=true
NEW_RELIC_INFRA_DISPLAY_NAME=livepoly
NEW_RELIC_INFRA_VERBOSE=0

MAIL_FROM="LivePoly <noreply@livepoly.site>"
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.livepoly.site/auth/oauth/google/callback
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=https://api.livepoly.site/auth/oauth/discord/callback
OAUTH_SUCCESS_REDIRECT_URL=https://www.livepoly.site/
OAUTH_FAILURE_REDIRECT_URL=https://www.livepoly.site/auth/login?oauth=failed

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=livepoly-user-image
R2_PUBLIC_BASE_URL=
R2_AVATAR_MAX_BYTES=10485760

BACKUP_S3_URI=s3://CHANGE_ME/livepoly/postgres
